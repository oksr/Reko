{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Reko",
  "version": "0.1.0",
  "identifier": "com.reko.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @reko/tauri dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @reko/app build && pnpm --filter @reko/tauri build",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "recorder",
        "title": "Reko",
        "width": 684,
        "height": 58,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/com.reko.app/**",
            "$HOME/Library/Application Support/com.reko.app/**",
            "$RESOURCE/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "resources": ["resources/wallpapers/*"],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "entitlements": "./Entitlements.plist"
    }
  }
}
